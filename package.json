{
	"name": "notectl-monorepo",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"test": "turbo run test",
		"test:e2e": "playwright test",
		"test:showcase": "playwright test showcase-cut-paste --project=chromium",
		"test:showcase:angular": "CI=true playwright test angular/showcase-cut-paste --project=angular",
		"preview:starlight": "pnpm --filter @notectl/core build && pnpm --filter docs-site build && pnpm --filter docs-site preview",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "turbo run typecheck",
		"dev": "turbo run dev"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@playwright/test": "^1.58.2",
		"turbo": "^2.8.17",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@9.15.0"
}
