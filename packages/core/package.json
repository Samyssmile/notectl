		},
		{
			"name": "Plugin: Super/Sub",
			"path": "dist/plugins/super-sub.mjs",
			"limit": "5 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Print",
			"path": "dist/plugins/print.mjs",
			"limit": "5 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Hard Break",
			"path": "dist/plugins/hard-break.mjs",
