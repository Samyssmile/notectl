{
	"name": "@notectl/core",
	"version": "2.0.0",
	"description": "A modern and accessible rich text editor shipped as a single Web Component. Immutable state, transaction-based architecture, and a plugin system that powers every feature.",
	"license": "MIT",
	"type": "module",
	"sideEffects": ["./dist/full.mjs", "./dist/notectl-core.umd.js"],
	"main": "./dist/notectl-core.umd.js",
	"module": "./dist/notectl-core.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/notectl-core.mjs"
		},
		"./full": {
			"types": "./dist/full.d.ts",
			"import": "./dist/full.mjs",
			"require": "./dist/notectl-core.umd.js"
		},
		"./html": {
			"types": "./dist/html.d.ts",
			"import": "./dist/html.mjs"
		},
		"./presets": {
			"types": "./dist/presets.d.ts",
			"import": "./dist/presets.mjs"
		},
		"./presets/minimal": {
			"types": "./dist/presets/minimal.d.ts",
			"import": "./dist/presets/minimal.mjs"
		},
		"./presets/full": {
			"types": "./dist/presets/full.d.ts",
			"import": "./dist/presets/full.mjs"
		},
		"./fonts": {
			"types": "./dist/fonts.d.ts",
			"import": "./dist/fonts.mjs"
		},
		"./plugins/text-formatting": {
			"types": "./dist/plugins/text-formatting/index.d.ts",
			"import": "./dist/plugins/text-formatting.mjs"
		},
		"./plugins/heading": {
			"types": "./dist/plugins/heading/index.d.ts",
			"import": "./dist/plugins/heading.mjs"
		},
		"./plugins/toolbar": {
			"types": "./dist/plugins/toolbar/index.d.ts",
			"import": "./dist/plugins/toolbar.mjs"
		},
		"./plugins/shared": {
			"types": "./dist/plugins/shared/index.d.ts",
			"import": "./dist/plugins/shared.mjs"
		},
		"./plugins/table": {
			"types": "./dist/plugins/table/index.d.ts",
			"import": "./dist/plugins/table.mjs"
		},
		"./plugins/image": {
			"types": "./dist/plugins/image/index.d.ts",
			"import": "./dist/plugins/image.mjs"
		},
		"./plugins/code-block": {
			"types": "./dist/plugins/code-block/index.d.ts",
			"import": "./dist/plugins/code-block.mjs"
		},
		"./plugins/link": {
			"types": "./dist/plugins/link/index.d.ts",
			"import": "./dist/plugins/link.mjs"
		},
		"./plugins/list": {
			"types": "./dist/plugins/list/index.d.ts",
			"import": "./dist/plugins/list.mjs"
		},
		"./plugins/blockquote": {
			"types": "./dist/plugins/blockquote/index.d.ts",
			"import": "./dist/plugins/blockquote.mjs"
		},
		"./plugins/strikethrough": {
			"types": "./dist/plugins/strikethrough/index.d.ts",
			"import": "./dist/plugins/strikethrough.mjs"
		},
		"./plugins/text-color": {
			"types": "./dist/plugins/text-color/index.d.ts",
			"import": "./dist/plugins/text-color.mjs"
		},
		"./plugins/horizontal-rule": {
			"types": "./dist/plugins/horizontal-rule/index.d.ts",
			"import": "./dist/plugins/horizontal-rule.mjs"
		},
		"./plugins/alignment": {
			"types": "./dist/plugins/alignment/index.d.ts",
			"import": "./dist/plugins/alignment.mjs"
		},
		"./plugins/font": {
			"types": "./dist/plugins/font/index.d.ts",
			"import": "./dist/plugins/font.mjs"
		},
		"./plugins/font-size": {
			"types": "./dist/plugins/font-size/index.d.ts",
			"import": "./dist/plugins/font-size.mjs"
		},
		"./plugins/highlight": {
			"types": "./dist/plugins/highlight/index.d.ts",
			"import": "./dist/plugins/highlight.mjs"
		},
		"./plugins/super-sub": {
			"types": "./dist/plugins/super-sub/index.d.ts",
			"import": "./dist/plugins/super-sub.mjs"
		},
		"./plugins/hard-break": {
			"types": "./dist/plugins/hard-break/index.d.ts",
			"import": "./dist/plugins/hard-break.mjs"
		},
		"./plugins/gap-cursor": {
			"types": "./dist/plugins/gap-cursor/index.d.ts",
			"import": "./dist/plugins/gap-cursor.mjs"
		},
		"./plugins/caret-navigation": {
			"types": "./dist/plugins/caret-navigation/index.d.ts",
			"import": "./dist/plugins/caret-navigation.mjs"
		},
		"./plugins/print": {
			"types": "./dist/plugins/print/index.d.ts",
			"import": "./dist/plugins/print.mjs"
		},
		"./plugins/text-direction": {
			"types": "./dist/plugins/text-direction/index.d.ts",
			"import": "./dist/plugins/text-direction.mjs"
		},
		"./plugins/text-direction-advanced": {
			"types": "./dist/plugins/text-direction-advanced/index.d.ts",
			"import": "./dist/plugins/text-direction-advanced.mjs"
		}
	},
	"customElements": "custom-elements.json",
	"files": ["dist", "README.md", "LICENSE", "custom-elements.json"],
	"keywords": [
		"rich-text-editor",
		"web-component",
		"contenteditable",
		"editor",
		"wysiwyg",
		"typescript",
		"plugin-system",
		"immutable-state",
		"notectl"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Samyssmile/notectl.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/Samyssmile/notectl",
	"bugs": {
		"url": "https://github.com/Samyssmile/notectl/issues"
	},
	"scripts": {
		"build": "vite build && vite build --config vite.config.umd.ts",
		"prepack": "cp ../../README.md ./README.md && cp ../../LICENSE ./LICENSE",
		"postpack": "rm -f ./README.md ./LICENSE",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"dev": "vite build --watch",
		"size": "size-limit",
		"size:check": "size-limit --limit",
		"build:analyze": "ANALYZE=true vite build"
	},
	"size-limit": [
		{
			"name": "Core (main entry)",
			"path": "dist/notectl-core.mjs",
			"limit": "75 KB",
			"gzip": true
		},
		{
			"name": "Presets (minimal)",
			"path": "dist/presets/minimal.mjs",
			"limit": "8 KB",
			"gzip": true
		},
		{
			"name": "Presets (full)",
			"path": "dist/presets/full.mjs",
			"limit": "68 KB",
			"gzip": true
		},
		{
			"name": "HTML (serializer/parser)",
			"path": "dist/html.mjs",
			"limit": "15 KB",
			"gzip": true
		},
		{
			"name": "Fonts (standalone)",
			"path": "dist/fonts.mjs",
			"limit": "300 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Table",
			"path": "dist/plugins/table.mjs",
			"limit": "22 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Text Formatting",
			"path": "dist/plugins/text-formatting.mjs",
			"limit": "10 KB",
