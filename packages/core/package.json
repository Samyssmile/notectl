	"dependencies": {
		"dompurify": "^3.3.1"
	},
	"devDependencies": {
		"@size-limit/preset-small-lib": "^12.0.0",
		"happy-dom": "^20.7.0",
		"rollup-plugin-visualizer": "^5.14.0",
		"size-limit": "^12.0.0",
		"terser": "^5.46.0",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.0.18"
	}
}
