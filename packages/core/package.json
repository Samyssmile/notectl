			"path": "dist/plugins/heading.mjs",
			"limit": "10 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Toolbar",
			"path": "dist/plugins/toolbar.mjs",
			"limit": "15 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Shared",
			"path": "dist/plugins/shared.mjs",
			"limit": "15 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Image",
			"path": "dist/plugins/image.mjs",
			"limit": "15 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Code Block",
			"path": "dist/plugins/code-block.mjs",
			"limit": "15 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Link",
			"path": "dist/plugins/link.mjs",
			"limit": "10 KB",
			"gzip": true
		},
		{
			"name": "Plugin: List",
			"path": "dist/plugins/list.mjs",
			"limit": "10 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Blockquote",
			"path": "dist/plugins/blockquote.mjs",
			"limit": "5 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Strikethrough",
			"path": "dist/plugins/strikethrough.mjs",
			"limit": "5 KB",
			"gzip": true
		},
		{
			"name": "Plugin: Text Color",
			"path": "dist/plugins/text-color.mjs",
			"limit": "10 KB",
